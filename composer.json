{
    "name": "produman-org/doctrine-encryption",
    "description": "A Symfony bundle that encrypts Doctrine entity fields with Halite.",
    "type": "symfony-bundle",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ProdumanOrg\\DoctrineEncryption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProdumanOrg\\DoctrineEncryption\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-sodium": "*",
        "doctrine/doctrine-bundle": "^2.12 || ^3.0",
        "doctrine/orm": "^2.20 || ^3.3",
        "paragonie/halite": "^5.1",
        "symfony/config": "^6.4 || ^7.4",
        "symfony/console": "^6.4 || ^7.4",
        "symfony/dependency-injection": "^6.4 || ^7.4",
        "symfony/http-kernel": "^6.4 || ^7.4"
    },
    "require-dev": {
        "ext-pdo_sqlite": "*",
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/var-exporter": "^6.4 || ^7.4"
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "keywords": [
        "doctrine",
        "encryption",
        "field-encryption",
        "halite",
        "symfony-bundle"
    ],
    "support": {
        "issues": "https://github.com/produman-org/doctrine-encryption/issues",
        "source": "https://github.com/produman-org/doctrine-encryption"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    }
}
